[
  {
    "key": "output|A_nearby_whistle_blows_before_a_visible_cloud_of_steam_briefly_a|940d1475769b",
    "original": "A nearby whistle blows before a visible cloud of steam briefly appears around you. You hear the gears cranking and axles turning before feeling the metal floor beneath you move. Not long after, the clacking clockwork mechanisms quickly carry the car across the impressive view of Gildenmere, then gradually slows to a stop before an audible woosh sounds, marking your arrival to your destination.",
    "translation": "",
    "stage": 0,
    "context": "&lt;&lt;POS:11488441&gt;&gt;"
  },
  {
    "key": "output|The_glass_chamber_closes_and_muffles_the_sounds_around_you_leav|f6fd1f44be1a",
    "original": "The glass chamber closes and muffles the sounds around you, leaving you with the faint noises of steam-powered hydraulics and turning gears--and an incredible view of Kressia. Before you know it, the elevator practically glides to its destination and you arrive with little fanfare. The doors open and the sounds of the busy populace instantly hit you once again.",
    "translation": "",
    "stage": 0,
    "context": "&lt;&lt;POS:11488868&gt;&gt;"
  },
  {
    "key": "output|With_audible_hydraulic_presses_whirring_gears_and_a_mechanical|0c8a8bdb3a32",
    "original": "With audible hydraulic presses, whirring gears and a mechanical hum, the cargo elevator powers up and shifts you towards the direction of your destination, then it slows down and quiets once you arrive.",
    "translation": "",
    "stage": 0,
    "context": "&lt;&lt;POS:11489263&gt;&gt;"
  },
  {
    "key": "output|Your_stomach_drops_as_the_lift_kicks_into_gear_The_gentle_stea|10475076be23",
    "original": "Your stomach drops as the lift kicks into gear. The gentle, steady thrum of powerful machinery fills the metallic tube as you are brought to your destination, slowly decelerating when you arrive.",
    "translation": "",
    "stage": 0,
    "context": "&lt;&lt;POS:11489537&gt;&gt;"
  },
