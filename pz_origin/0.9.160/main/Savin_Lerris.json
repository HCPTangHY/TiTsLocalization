kColor='red'"}, {"key": "assign|pink|41c684172be0", "original": "pink", "translation": "", "context": "<<POS:11602547>> reastRatingRaw=5,e.nippleColor='pink'"}, {"key": "assign|SYRI|c0bd17ca916c", "original": "SYRI", "translation": "", "context": "<<POS:11603292>> ==arguments[2]&&arguments[2],a='SYRI'"}, {"key": "assign|HECK|5e01a7651181", "original": "_HECK", "translation": "", "context": "<<POS:11603391>> d(),i=this.steeleSuit();n&&(a+='_HECK'"}, {"key": "assign|MAID|89757870b711", "original": "_MAID", "translation": "", "context": "<<POS:11603405>> eleSuit();n&&(a+=\"_HECK\"),t?a+='_MAID'"}, {"key": "assign|NUDE|a9f06b9eccac", "original": "_NUDE", "translation": "", "context": "<<POS:11603419>> a+=\"_HECK\"),t?a+=\"_MAID\":(e?a+='_NUDE'"}, {"key": "assign|STEELE|ad64e0f5e7f6", "original": "_STEELE", "translation": "", "context": "<<POS:11603434>> +=\"_MAID\":(e?a+=\"_NUDE\":i&&(a+='_STEELE'"}, {"key": "assign|COAT|db7a3c941fb9", "original": "_COAT", "translation": "", "context": "<<POS:11603523>> ory.armor.getClassName())&&(a+='_COAT'"}, {"key": "assign|NUDE|667862332fab", "original": "_NUDE", "translation": "", "context": "<<POS:11603545>> ())&&(a+=\"_COAT\"))}else e&&(a+='_NUDE'"}, {"key": "button|Syri|f85b887e9ec8", "original": "Syri", "translation": "", "context": "<<POS:11606711>> addButton(arguments.length>0&&void 0!==arguments[0]?arguments[0]:0,\"Syri\",this.crewApproach)"}, {"key": "string.array|Syri_s_closed_the_doors_to_her_quarters_but_even_through_the|f66d05b1cb02", "original": "[\"Syri’s closed the doors to her quarters, but even through the armored bulkhead you can hear her shouting and ranting about whatever’s going wrong -- or maybe hilariously right -- in her game of the day. Occasionally the noise dies down as she thanks a new subscriber, or comes jogging out for a quick snack. Whenever she does leave her quarters, though, she’s sure to swing by and give you a smooch no matter what you’re doing.\",\"You catch sight of Syri sitting in her quarters through a door she’s deliberately left open. The gamer pup’s hooked her feet onto the side of her bed while she does pushups in nothing but a tanktop and boxers. <i>“Seventy-one! Seventy-two! Seventy-three!”</i>\",\"Syri’s crashed out on your couch, curled up into an adorably canine ball with her tablet. Her raven tail is flipped up over her face, hiding her from the world as she loses herself in that of whatever book she’s so engrossed in. She barely reacts when you walk by, just giving you a noncommittal <i>“Hey,”</i> and a two-fingered wave.\",\"You can notice Syri’s sitting in her quarters with the door open, sitting cross-legged at her desk. She’s got a bass guitar, a real classic with no holos or anything, sat in her lap and is strumming away at it with her claws covered up by leather gloves. She’s not... great at it... but you’re sure that layered on top of whatever that noise pumping through her headphones is, it must sound epic.\"]", "translation": "", "context": "<<POS:11606754>> '[\"Syri’s closed the doors to her quarters, but even through the armored bulkhead'..."}, {"key": "textify|var0_n_t_t_t_You_wander_over_to_Syri_s_quarters_and_taking_not|5d94a3faae9b", "original": "[var0\\n\\t\\t\\t|You wander over to Syri’s quarters and, taking note of a paper sign taped to it that says “LIVE ON AIR,” give a quiet knock before poking your head in. \\n\\t\\t\\t\\n\\t\\t\\tSyri waves then taps her headset. <i>“Oooookay, guys, I’m gonna take a quick break here. Enjoy some nice ads while I’m gone, ‘kay?”</i>\\n\\t\\t\\t\\n\\t\\t\\tShe quickly fiddles with a few settings on her Codex before sighing and pulling her headset off, shaking her hair out with a smile. <i>“What’s up, [syri.isLover\\n\\t\\t\\t\\t|lover\\n\\t\\t\\t\\t|captain\\n\\t\\t\\t]?”</i>\\n\\t\\t\\t|You wander over to Syri’s quarters, giving a knock on the door to announce yourself. You hear the clatter of a headset being tossed before she comes to the door and lets you in, greeting you with [syri.isLover\\n\\t\\t\\t\\t|a kiss\\n\\t\\t\\t\\t|a big hug\\n\\t\\t\\t]. <i>“Hey, [syri.isLover\\n\\t\\t\\t\\t|lover\\n\\t\\t\\t\\t|cap\\n\\t\\t\\t]. What’s up?”</i>\\n\\t\\t]", "translation": "", "context": "<<POS:11608803>> textify(['\\\\n\\\\t\\\\t[var0\\\\n\\\\t\\\\t\\\\t|You wander over to Syri’s quar'...])"}, {"key": "assign|human|de678b0bacbd", "original": "human", "translation": "", "context": "<<POS:11610917>> verSerialize=!1,e.originalRace='human'"}, {"key": "assign|red|12b6f8d38a68", "original": "red", "translation": "", "context": "<<POS:11611312>> nity=40,e.eyeType=0,e.eyeColor='red'"}, {"key": "assign|black|41111bb35557", "original": "black", "translation": "", "context": "<<POS:11611370>> kness=40,e.tone=99,e.hairColor='black'"}, {"key": "assign|bronze|c585ed22ca37", "original": "bronze", "translation": "", "context": "<<POS:11611391>> hairColor=\"black\",e.scaleColor='bronze'"}, {"key": "assign|dark_brown|ffce9da80919", "original": "dark brown", "translation": "", "context": "<<POS:11611411>> scaleColor=\"bronze\",e.furColor='dark brown'"}, {"key": "assign|pink|2d972926b3bf", "original": "pink", "translation": "", "context": "<<POS:11611549>> LOBAL.SKIN_TYPE_FUR,e.skinTone='pink'"}, {"key": "assign|pink|15794a9ace89", "original": "pink", "translation": "", "context": "<<POS:11612267>> E_VULPINE,e.cocks[0].cockColor='pink'"}, {"key": "assign|pink|15794a9ace89#1", "original": "pink", "translation": "", "context": "<<POS:11612881>> reastRatingRaw=0,e.nippleColor='pink'"}, {"key": "perk|Musky_Pheromones|8ef1f0d3ad81", "original": "Musky Pheromones", "translation": "", "context": "<<POS:11613023>> createPerk(\"Musky Pheromones\")"}, {"key": "assign|Magenta_Needle|c5278c4016e1", "original": "Magenta Needle", "translation": "", "context": "<<POS:11613060>> Pheromones\"),e.originalAuthor='Magenta Needle'"}, {"key": "assign|Yammi|b6782f96fdda", "original": "Yammi", "translation": "", "context": "<<POS:11614294>> e),e.neverSerialize=!1,e.short='Yammi'"}, {"key": "assi